# App
APP_BASE_URL=http://localhost:3000
PURCHASE_LINK_DEFAULT=https://example.com/default-supplement
IMAGE_PLACEHOLDER_URL=https://example.com/placeholder.png

# Firebase Admin SDK (Service Account)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----\\n"

# LINE backend integration mode
# mock: モック送信
# line: 実際のMessaging API送信
LINE_SERVICE_MODE=mock

# どのLINE公式アカウント系統のデータかを識別するキー
# 例: temp / prod
LINE_ACCOUNT_KEY=temp

# LINE Messaging API credentials
# LINE_SERVICE_MODE=line の場合は必須
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_API_BASE_URL=https://api.line.me

# LINE identity mode for client UI
# manual: 手入力
# liff: LIFF SDKで自動取得
NEXT_PUBLIC_LINE_IDENTITY_MODE=manual
NEXT_PUBLIC_LIFF_ID=

# 参考
# LINE_FRIEND_ADD_URL=
# LINE_WEBHOOK_URL=
